VALUES (@p0, @p1, @p2, @p3, @p4, @p5, @p6);
UPDATE [iam].[LoginMfaChallenge] SET [FailedAttemptCount] = @p7, [StatusCode] = @p8
OUTPUT 1
WHERE [LoginMfaChallengeId] = @p9;
UPDATE [iam].[LoginMfaCredential] SET [FailedAttemptCount] = @p10, [UpdatedAtUtc] = @p11
OUTPUT INSERTED.[RowVersion]
WHERE [LoginMfaCredentialId] = @p12 AND [RowVersion] = @p13;
