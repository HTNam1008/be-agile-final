{
  "UAT": {
    "EnableMockIntegrations": true,
    "EnableSwagger": true
  },
  "BackgroundJobs": {
    "Enabled": true,
    "CourseBilling": {
      "MonthlyBillNotifications": true,
      "MissedInstallmentPaymentEmails": true
    },
    "EducationAccountTopUp": {
      "Scheduler": true,
      "RunWorker": true,
      "Assessment": true,
      "Lifecycle": true
    },
    "AiCopilot": {
      "Retention": true
    },
    "MailDelivery": {
      "QueueWorker": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Moe": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Information",
      "System.Net.Http.HttpClient": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  }
}
